{
  "manifest_version": 3,
  "name": "AdaptiRead",
  "version": "1.0",
  "description": "AI-powered English learning browser extension that simplifies language based on your proficiency.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles/content.css"
      ]
    }
  ]
}